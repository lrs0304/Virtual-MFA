<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools">

    <!-- 仅声明相机权限用于扫码；不声明 INTERNET、ACCESS_NETWORK_STATE 等任何联网权限 -->
    <uses-permission android:name="android.permission.CAMERA" />
    <uses-feature android:name="android.hardware.camera" android:required="false" />
    <uses-feature android:name="android.hardware.camera.autofocus" android:required="false" />

    <!-- 显式拒绝 ZXing 库可能传入的 INTERNET 权限 -->
    <uses-permission android:name="android.permission.INTERNET" tools:node="remove" />
    <uses-permission android:name="android.permission.ACCESS_NETWORK_STATE" tools:node="remove" />

    <application
        android:allowBackup="false"
        android:dataExtractionRules="@xml/data_extraction_rules"
        android:fullBackupContent="@xml/backup_rules"
        android:icon="@mipmap/ic_launcher"
        android:label="@string/app_name"
        android:roundIcon="@mipmap/ic_launcher_round"
        android:supportsRtl="true"
        android:usesCleartextTraffic="false"
        android:theme="@style/Theme.MFA">

        <!--
            包体瘦身：移除第三方依赖通过 manifest merger 注入但本应用并不需要的组件。
            理由：本 App 是纯本地 MFA，已禁用网络权限，不上报、不预热启动 profile。
            - androidx.startup.InitializationProvider / ProfileInstallReceiver：
              来自 androidx.profileinstaller，用于启动期安装 baseline profile，
              我们不维护 profile，留之无意义。
            - com.google.android.datatransport.* (TransportBackendDiscovery /
              JobInfoSchedulerService / AlarmManagerSchedulerBroadcastReceiver)：
              来自 ML Kit 的 Firelog 上报链路，无网络权限下永远跑不起来。
            - com.journeyapps.barcodescanner.CaptureActivity：
              zxing-android-embedded 自带的扫码 Activity，本项目使用自实现的
              ScanActivity，无需暴露这个组件。
            移除后，R8 会进一步裁剪相关类，APK 体积减少且 manifest 更干净，
            也便于上架审核解释"为何无网"。
        -->
        <provider
            android:name="androidx.startup.InitializationProvider"
            android:authorities="${applicationId}.androidx-startup"
            tools:node="remove"
            tools:ignore="Instantiatable,MissingClass" />
        <receiver
            android:name="androidx.profileinstaller.ProfileInstallReceiver"
            tools:node="remove"
            tools:ignore="Instantiatable,MissingClass" />
        <service
            android:name="com.google.android.datatransport.runtime.backends.TransportBackendDiscovery"
            tools:node="remove"
            tools:ignore="Instantiatable,MissingClass" />
        <service
            android:name="com.google.android.datatransport.runtime.scheduling.jobscheduling.JobInfoSchedulerService"
            tools:node="remove"
            tools:ignore="Instantiatable,MissingClass" />
        <receiver
            android:name="com.google.android.datatransport.runtime.scheduling.jobscheduling.AlarmManagerSchedulerBroadcastReceiver"
            tools:node="remove"
            tools:ignore="Instantiatable,MissingClass" />
        <activity
            android:name="com.journeyapps.barcodescanner.CaptureActivity"
            tools:node="remove"
            tools:ignore="Instantiatable,MissingClass" />

        <activity
            android:name=".ui.MainActivity"
            android:exported="true"
            android:launchMode="singleTop">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity>

        <activity
            android:name=".ui.LockActivity"
            android:exported="false"
            android:excludeFromRecents="true"
            android:launchMode="singleTop"
            android:theme="@style/Theme.MFA" />

        <activity
            android:name=".ui.AddManualActivity"
            android:exported="false"
            android:label="@string/title_add_manual"
            android:parentActivityName=".ui.MainActivity" />

        <activity
            android:name=".ui.ScanActivity"
            android:exported="false"
            android:screenOrientation="portrait"
            android:stateNotNeeded="true"
            android:theme="@style/Theme.AppCompat.NoActionBar" />

        <activity
            android:name=".ui.ImportExportActivity"
            android:exported="false"
            android:label="@string/title_import_export"
            android:parentActivityName=".ui.MainActivity" />

        <activity
            android:name=".ui.SettingsActivity"
            android:exported="false"
            android:label="@string/title_settings"
            android:parentActivityName=".ui.MainActivity" />
    </application>

</manifest>