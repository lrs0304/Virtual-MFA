<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/root_container"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@color/brand_primary">

    <!--
        顶部用 AppBarLayout 包裹 MaterialToolbar：AppBarLayout 自身
        fitsSystemWindows=true 会消费 status bar inset 并把 toolbar 推到
        状态栏下方，避免与系统状态栏叠加。其他 Activity 也是同一写法。
    -->
    <com.google.android.material.appbar.AppBarLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@color/brand_primary"
        android:fitsSystemWindows="true">

        <com.google.android.material.appbar.MaterialToolbar
            android:id="@+id/toolbar"
            android:layout_width="match_parent"
            android:layout_height="?attr/actionBarSize"
            app:title="@string/title_qr_content_preview"
            app:titleTextColor="@color/text_inverse"
            app:navigationIconTint="@color/text_inverse" />
    </com.google.android.material.appbar.AppBarLayout>

    <!-- 失败提示条：紧贴 AppBar，告知用户无法添加的原因和当前内容长度 -->
    <TextView
        android:id="@+id/tv_hint"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@color/hint_bg_error"
        android:textColor="@color/hint_text_error"
        android:textSize="13sp"
        android:lineSpacingExtra="2dp"
        android:paddingHorizontal="16dp"
        android:paddingVertical="12dp"
        tools:text="二维码内容不符合 MFA 规范" />

    <!--
        内容区 + 底部按钮区共用 bg_card 白底，避免 ScrollView 灰底透过
        圆角弧外区域形成"卡片四角灰边"的视觉错觉。失败提示条已经用了
        独立的浅红色背景做分区。

        内容卡片用一个带 card_outline 背景的容器实现描边效果：背景与
        外层 ScrollView 同为 bg_card 白色，描边来自 drawable 自身，
        圆角外侧不会再透出 bg_window 灰底。
    -->
    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:background="@color/bg_card"
        android:padding="16dp"
        android:clipToPadding="false"
        android:fillViewport="true"
        android:scrollbarSize="3dp"
        android:scrollbarThumbVertical="@drawable/scrollbar_thumb_thin"
        android:scrollbarStyle="outsideOverlay"
        android:scrollbarFadeDuration="500"
        android:scrollbarDefaultDelayBeforeFade="800">

        <FrameLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="@drawable/card_outline">

            <TextView
                android:id="@+id/tv_content"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:padding="16dp"
                android:textColor="@color/text_primary"
                android:textSize="14sp"
                android:textIsSelectable="true"
                android:fontFamily="monospace"
                android:lineSpacingExtra="2dp"
                tools:text="otpauth://totp/..." />

        </FrameLayout>

    </ScrollView>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@color/bg_card"
        android:orientation="horizontal"
        android:padding="16dp"
        android:gravity="end">

        <Button
            android:id="@+id/btn_close"
            style="?attr/borderlessButtonStyle"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:minWidth="96dp"
            android:text="@string/action_close"
            android:textColor="@color/text_secondary" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btn_copy"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="8dp"
            android:minWidth="120dp"
            android:text="@string/action_copy_content" />

    </LinearLayout>

</LinearLayout>
