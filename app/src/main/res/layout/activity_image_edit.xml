<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/root_container"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@color/bg_window"
    android:fitsSystemWindows="true">

    <androidx.appcompat.widget.Toolbar
        android:id="@+id/toolbar"
        android:layout_width="match_parent"
        android:layout_height="?attr/actionBarSize"
        android:background="@color/brand_primary"
        app:titleTextColor="@color/text_inverse"
        app:navigationIcon="?attr/homeAsUpIndicator" />

    <!-- 模式提示条 -->
    <TextView
        android:id="@+id/tv_hint"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="#FFFFF8E1"
        android:textColor="#FF6D4C00"
        android:textSize="13sp"
        android:lineSpacingExtra="2dp"
        android:paddingHorizontal="16dp"
        android:paddingVertical="10dp"
        tools:text="@string/image_edit_hint_zoom" />

    <!-- 正方形图片预览区：宽度撑满，高度=宽度（通过 ConstraintLayout 1:1 比例） -->
    <androidx.constraintlayout.widget.ConstraintLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="#FF000000"
        android:padding="0dp">

        <com.risonliang.mfa.ui.ZoomableImageView
            android:id="@+id/zoom_image"
            android:layout_width="0dp"
            android:layout_height="0dp"
            app:layout_constraintDimensionRatio="H,1:1"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            android:contentDescription="@string/title_image_edit" />

        <ProgressBar
            android:id="@+id/progress_decoding"
            android:layout_width="48dp"
            android:layout_height="48dp"
            android:visibility="gone"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            tools:visibility="visible" />

    </androidx.constraintlayout.widget.ConstraintLayout>

    <!-- 模式切换 + 重新识别按钮 -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:paddingHorizontal="16dp"
        android:paddingVertical="12dp">

        <com.google.android.material.button.MaterialButtonToggleGroup
            android:id="@+id/toggle_mode"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            app:singleSelection="true"
            app:selectionRequired="true">

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btn_mode_zoom"
                style="?attr/materialButtonOutlinedStyle"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:minWidth="72dp"
                android:text="@string/action_mode_zoom" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btn_mode_adjust"
                style="?attr/materialButtonOutlinedStyle"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:minWidth="72dp"
                android:text="@string/action_mode_adjust" />

        </com.google.android.material.button.MaterialButtonToggleGroup>

        <View
            android:layout_width="0dp"
            android:layout_height="1dp"
            android:layout_weight="1" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btn_retry"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:minWidth="120dp"
            android:text="@string/action_retry_decode" />

    </LinearLayout>

    <!-- 调整模式控件区：滑块 + 二值化/反色/重置按钮（mode=adjust 时显示） -->
    <ScrollView
        android:id="@+id/sv_adjust_panel"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:visibility="gone"
        android:background="@color/bg_card"
        android:fillViewport="true">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="16dp">

            <!-- 对比度 -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical">

                <TextView
                    android:layout_width="80dp"
                    android:layout_height="wrap_content"
                    android:text="@string/label_contrast"
                    android:textColor="@color/text_primary"
                    android:textSize="14sp" />

                <SeekBar
                    android:id="@+id/sb_contrast"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:max="250"
                    android:progress="50" />

                <TextView
                    android:id="@+id/tv_contrast_val"
                    android:layout_width="48dp"
                    android:layout_height="wrap_content"
                    android:gravity="end"
                    android:textColor="@color/text_secondary"
                    android:textSize="13sp"
                    tools:text="1.0x" />
            </LinearLayout>

            <!-- 阈值 (-1=off, 0..255=enabled) -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:orientation="horizontal"
                android:gravity="center_vertical">

                <TextView
                    android:layout_width="80dp"
                    android:layout_height="wrap_content"
                    android:text="@string/label_threshold"
                    android:textColor="@color/text_primary"
                    android:textSize="14sp" />

                <SeekBar
                    android:id="@+id/sb_threshold"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:max="256"
                    android:progress="0" />

                <TextView
                    android:id="@+id/tv_threshold_val"
                    android:layout_width="48dp"
                    android:layout_height="wrap_content"
                    android:gravity="end"
                    android:textColor="@color/text_secondary"
                    android:textSize="13sp"
                    tools:text="OFF" />
            </LinearLayout>

            <!-- R 亮度 -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:orientation="horizontal"
                android:gravity="center_vertical">

                <TextView
                    android:layout_width="80dp"
                    android:layout_height="wrap_content"
                    android:text="@string/label_brightness_r"
                    android:textColor="#FFD32F2F"
                    android:textSize="14sp" />

                <SeekBar
                    android:id="@+id/sb_r"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:max="254"
                    android:progress="127" />

                <TextView
                    android:id="@+id/tv_r_val"
                    android:layout_width="48dp"
                    android:layout_height="wrap_content"
                    android:gravity="end"
                    android:textColor="@color/text_secondary"
                    android:textSize="13sp"
                    tools:text="0" />
            </LinearLayout>

            <!-- G 亮度 -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                android:orientation="horizontal"
                android:gravity="center_vertical">

                <TextView
                    android:layout_width="80dp"
                    android:layout_height="wrap_content"
                    android:text="@string/label_brightness_g"
                    android:textColor="#FF388E3C"
                    android:textSize="14sp" />

                <SeekBar
                    android:id="@+id/sb_g"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:max="254"
                    android:progress="127" />

                <TextView
                    android:id="@+id/tv_g_val"
                    android:layout_width="48dp"
                    android:layout_height="wrap_content"
                    android:gravity="end"
                    android:textColor="@color/text_secondary"
                    android:textSize="13sp"
                    tools:text="0" />
            </LinearLayout>

            <!-- B 亮度 -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                android:orientation="horizontal"
                android:gravity="center_vertical">

                <TextView
                    android:layout_width="80dp"
                    android:layout_height="wrap_content"
                    android:text="@string/label_brightness_b"
                    android:textColor="#FF1976D2"
                    android:textSize="14sp" />

                <SeekBar
                    android:id="@+id/sb_b"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:max="254"
                    android:progress="127" />

                <TextView
                    android:id="@+id/tv_b_val"
                    android:layout_width="48dp"
                    android:layout_height="wrap_content"
                    android:gravity="end"
                    android:textColor="@color/text_secondary"
                    android:textSize="13sp"
                    tools:text="0" />
            </LinearLayout>

            <!-- 动作按钮区：反色 / 自动 / 重置 -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:orientation="horizontal">

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btn_invert"
                    style="?attr/materialButtonOutlinedStyle"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="@string/action_invert" />

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btn_otsu"
                    style="?attr/materialButtonOutlinedStyle"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:layout_marginStart="8dp"
                    android:text="@string/action_otsu" />

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btn_reset"
                    style="?attr/materialButtonOutlinedStyle"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:layout_marginStart="8dp"
                    android:text="@string/action_reset_adjust" />

            </LinearLayout>

        </LinearLayout>

    </ScrollView>

</LinearLayout>
