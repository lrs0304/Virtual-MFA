<resources xmlns:tools="http://schemas.android.com/tools">
    <!--
        深色主题：继承 values/themes.xml 的所有设置，仅在需要时覆写。
        windowBackground 改为引用 @color/bg_window（已在 values-night/colors.xml
        覆写为 #121212），这样未来再调暗色窗体色只需改一处。

        statusBar/navigationBar 仍走透明 + windowDrawsSystemBarBackgrounds 的
        edge-to-edge 方案（继承自父主题），由各 Activity 的 AppBarLayout
        通过 fitsSystemWindows 接管 inset。
    -->
    <style name="Theme.MFA" parent="Theme.MaterialComponents.DayNight.NoActionBar">
        <!-- Primary brand color. -->
        <item name="colorPrimary">@color/brand_primary</item>
        <item name="colorPrimaryVariant">@color/brand_primary_dark</item>
        <item name="colorOnPrimary">@color/text_inverse</item>
        <!-- Secondary brand color. -->
        <item name="colorSecondary">@color/brand_accent</item>
        <item name="colorSecondaryVariant">@color/brand_accent</item>
        <item name="colorOnSecondary">@color/text_inverse</item>
        <!-- Status bar / navigation bar：使用半透明并由内容延伸覆盖，配合 insets 处理安全区。 -->
        <item name="android:statusBarColor" tools:targetApi="l">@android:color/transparent</item>
        <item name="android:navigationBarColor" tools:targetApi="l">@android:color/transparent</item>
        <item name="android:windowDrawsSystemBarBackgrounds" tools:targetApi="l">true</item>
        <!-- 允许内容绘制到刘海/水滴屏区域（横竖屏均生效），由代码统一处理安全距离。 -->
        <item name="android:windowLayoutInDisplayCutoutMode" tools:targetApi="o_mr1">shortEdges</item>
        <!-- Window background：引用主题色变量，深浅模式自动切换。 -->
        <item name="android:windowBackground">@color/bg_window</item>
    </style>
</resources>
